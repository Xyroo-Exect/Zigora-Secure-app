<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Theme.ZigoraSecure" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="android:windowBackground">@color/bg_dark</item>
        <item name="android:statusBarColor">@color/bg_dark</item>
        <item name="android:navigationBarColor">@color/bg_dark</item>
        <item name="android:windowLightStatusBar" tools:targetApi="27">false</item>
    </style>

    <!-- Splash theme — tampil sebentar sebelum MainActivity render WebView -->
    <style name="Theme.ZigoraSecure.Splash" parent="Theme.ZigoraSecure">
        <item name="android:windowBackground">@drawable/splash_background</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowFullscreen">false</item>
    </style>

</resources>
